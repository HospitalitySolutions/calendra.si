# Docker Compose reads this file automatically as the project environment (copy to ".env").
# Do not commit ".env". For "mvn spring-boot:run" use backend/.env.local instead.

# Production container images are built by GitHub Actions and stored in GHCR.
# Use a full Git commit SHA for deterministic deployments; use latest only for initial setup.
CALENDRA_IMAGE_REGISTRY=ghcr.io/hospitalitysolutions
CALENDRA_IMAGE_TAG=latest

# Container limits for the current single-server production topology.
BACKEND_MEMORY_LIMIT=2g
BACKEND_CPU_LIMIT=2.0
FRONTEND_MEMORY_LIMIT=512m
FRONTEND_CPU_LIMIT=0.5

# Required backend secrets. Use unique random values; production should load these from AWS Secrets Manager.
APP_JWT_SECRET=replace-with-at-least-32-characters-random-string
APP_SETTINGS_ENCRYPTION_KEY=replace-with-at-least-32-characters-random-settings-key
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_SECRET=replace-with-at-least-32-characters-random-google-token-key

# One-time platform superadmin bootstrap. Disabled by default.
# Enable only for initial production/staging bootstrap, then set APP_BOOTSTRAP_SUPERADMIN_ENABLED=false again.
# The password must be at least 16 chars and include uppercase, lowercase, digit, and special character.
# APP_BOOTSTRAP_SUPERADMIN_ENABLED=false
# APP_BOOTSTRAP_SUPERADMIN_EMAIL=info@calendra.si
# APP_BOOTSTRAP_SUPERADMIN_PASSWORD=
# APP_BOOTSTRAP_SUPERADMIN_FIRST_NAME=Platform
# APP_BOOTSTRAP_SUPERADMIN_LAST_NAME=Admin
# APP_BOOTSTRAP_SUPERADMIN_COMPANY_NAME=Platform Admin

# Platform notifications. New-tenant notifications use APP_PLATFORM_ADMIN_EMAILS.
# Multiple recipients can be comma-separated. If omitted, APP_PLATFORM_ALERT_EMAILS is used,
# with info@calendra.si as the final fallback.
# APP_PLATFORM_ADMIN_EMAILS=info@calendra.si
# APP_PLATFORM_ADMIN_TIME_ZONE=Europe/Ljubljana
# Shared public app/base URL used for frontend redirects and public backend /api callbacks.
# In production this can be the only public URL variable you need, for example https://app.calendra.si.
APP_PUBLIC_BASE_URL=http://localhost:3000
# Optional legacy override for auth redirects/WebAuthn if it differs from APP_PUBLIC_BASE_URL.
# APP_AUTH_FRONTEND_URL=http://localhost:3000
# Optional WebAuthn overrides. Defaults are derived from APP_AUTH_FRONTEND_URL or APP_PUBLIC_BASE_URL.
# APP_WEBAUTHN_RP_ID=localhost
# APP_WEBAUTHN_RP_NAME=Calendra
# APP_WEBAUTHN_ALLOWED_ORIGINS=http://localhost:3000


# Production/staging database passwords are intentionally not stored in .env files.
# Put POSTGRES_PASSWORD in AWS Secrets Manager, or use SPRING_DATASOURCE_PASSWORD as the same value.
# Start compose through scripts/docker-compose-with-aws-secrets.sh so the Postgres container gets the password at runtime.
# Optional: set exact production secret id/name. Full ARN is safest.
AWS_PRODUCTION_SECRET_ID=calendra-app

# Optional: set exact staging secret id/name. Full ARN is safest (avoids account/name ambiguity).
AWS_STAGING_SECRET_ID=arn:aws:secretsmanager:eu-central-1:345362761828:secret:calendra/staging-2jqRIf

# If backend container cannot use instance/task role (e.g. cross-account secret), provide credentials:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-central-1

# Optional legacy public callback overrides. Normally use APP_PUBLIC_BASE_URL instead.
# APP_PAYPAL_PUBLIC_BASE_URL=https://your-public-api-host.example.com
# APP_STRIPE_GUEST_PUBLIC_BASE_URL=https://app.calendra.si
# APP_STRIPE_BILLING_PUBLIC_BASE_URL=https://app.calendra.si

# Production scale / multi-instance realtime. Enable when more than one backend instance can serve SSE clients.
# APP_REALTIME_REDIS_ENABLED=true
# APP_REALTIME_REDIS_CHANNEL=calendra:session-bookings:events
# STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# Delivery log retention. Default keeps Dnevniki pošiljanja for 30 days.
# APP_DELIVERY_LOG_RETENTION=P30D
# APP_DELIVERY_LOG_RETENTION_CRON=0 37 2 * * *

# Optional A1 Crosschat SMS
# A1_CROSSCHAT_SMS_AUTH_TOKEN=
# A1_CROSSCHAT_SMS_USE_TEST_ENVIRONMENT=true
# Bunny video/audio storage (do not commit real credentials)
APP_BUNNY_ENABLED=true
BUNNY_API_KEY=
BUNNY_CORE_BASE_URL=https://api.bunny.net
BUNNY_STREAM_BASE_URL=https://video.bunnycdn.com
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_REGION_HOST=https://storage.bunnycdn.com
BUNNY_AUDIO_CDN_HOST=
APP_MULTIPART_MAX_FILE_SIZE=512MB
APP_MULTIPART_MAX_REQUEST_SIZE=520MB


# Google Places ratings for the public company directory (calendra.si/stranke).
# Keep this key server-side and restrict it to Places API (New).
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_ENABLED=true
GOOGLE_PLACES_AUTOMATIC_TEXT_SEARCH_ENABLED=true
GOOGLE_PLACES_CONNECT_TIMEOUT=2s
GOOGLE_PLACES_READ_TIMEOUT=3s
GOOGLE_PLACES_MAX_CONCURRENT_LOOKUPS=6

# Public registration contact form rate limits per 60-second window.
# APP_RATE_LIMIT_REGISTER_CONTACT_PER_IP=6
# APP_RATE_LIMIT_REGISTER_CONTACT_PER_IDENTITY=3

# Public website used for the demo-booking page and internal booking-source links
APP_DEMO_BOOKING_PUBLIC_BASE_URL=https://calendra.si
# Frontend that serves the public reschedule/cancel page. Keep this on the app host.
APP_DEMO_BOOKING_MANAGEMENT_BASE_URL=https://app.calendra.si
