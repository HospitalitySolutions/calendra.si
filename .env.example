# Docker Compose reads this file automatically as the project environment (copy to ".env").
# Do not commit ".env". For "mvn spring-boot:run" use backend/.env.local instead.

# Required when backend needs JWT (always):
APP_JWT_SECRET=replace-with-at-least-32-characters-random-string
# Shared public app/base URL used for frontend redirects and public backend /api callbacks.
# In production this can be the only public URL variable you need, for example https://app.calendra.si.
APP_PUBLIC_BASE_URL=http://localhost:3000
# Optional legacy override for auth redirects/WebAuthn if it differs from APP_PUBLIC_BASE_URL.
# APP_AUTH_FRONTEND_URL=http://localhost:3000
# Optional WebAuthn overrides. Defaults are derived from APP_AUTH_FRONTEND_URL or APP_PUBLIC_BASE_URL.
# APP_WEBAUTHN_RP_ID=localhost
# APP_WEBAUTHN_RP_NAME=Calendra
# APP_WEBAUTHN_ALLOWED_ORIGINS=http://localhost:3000

# Optional: set exact staging secret id/name. Full ARN is safest (avoids account/name ambiguity).
AWS_STAGING_SECRET_ID=arn:aws:secretsmanager:eu-central-1:345362761828:secret:calendra/staging-2jqRIf

# If backend container cannot use instance/task role (e.g. cross-account secret), provide credentials:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-central-1

# Optional legacy public callback overrides. Normally use APP_PUBLIC_BASE_URL instead.
# APP_PAYPAL_PUBLIC_BASE_URL=https://your-public-api-host.example.com
# APP_STRIPE_GUEST_PUBLIC_BASE_URL=https://app.calendra.si
# APP_STRIPE_BILLING_PUBLIC_BASE_URL=https://app.calendra.si

# Optional A1 Crosschat SMS
# A1_CROSSCHAT_SMS_AUTH_TOKEN=
# A1_CROSSCHAT_SMS_USE_TEST_ENVIRONMENT=true
