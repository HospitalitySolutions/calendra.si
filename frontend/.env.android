# Used by: npm run build:android (physical device on same Wi‑Fi as PC)
#
# Emulator build: use npm run build:android:emu (see .env.androidemu).
# Test reachability in a browser: GET http://YOUR_PC:4000/api/auth/ping  → JSON { "status":"ok", ... }
# Opening /api/auth/login in a tab uses GET → 405 is normal (login is POST only).
VITE_API_URL=http://192.168.1.83:4000/api
