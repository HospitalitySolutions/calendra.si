{
  "name": "therapy-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "vite",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint src --max-warnings=0",
    "knip": "knip --include files,dependencies,unlisted,unresolved,duplicates",
    "build": "tsc -b && vite build",
    "build:android": "tsc -b && vite build --mode android",
    "build:android:emu": "tsc -b && vite build --mode androidemu",
    "preview": "vite preview",
    "build:staging": "tsc -b && vite build --mode staging",
    "prebuild:production": "node scripts/validate-production-env.mjs",
    "build:production": "tsc -b && vite build --mode production",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "quality": "npm run typecheck && npm run lint && npm run knip"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.17",
    "@fullcalendar/daygrid": "^6.1.17",
    "@fullcalendar/interaction": "^6.1.17",
    "@fullcalendar/react": "^6.1.17",
    "@fullcalendar/resource": "^6.1.20",
    "@fullcalendar/resource-daygrid": "^6.1.20",
    "@fullcalendar/resource-timegrid": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.17",
    "@tanstack/react-query": "^5.76.1",
    "@zxing/browser": "^0.2.0",
    "axios": "^1.18.1",
    "dompurify": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.5.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "knip": "^6.27.0",
    "patch-package": "^8.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^6.2.5"
  },
  "engines": {
    "node": ">=24"
  }
}
