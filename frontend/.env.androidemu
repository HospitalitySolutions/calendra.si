# Used by: npm run build:android:emu (Android Emulator → host computer)
# 10.0.2.2 is the emulator’s alias for the host loopback (no adb reverse needed).
# Optional: run `adb reverse tcp:4000 tcp:4000` and set VITE_API_HOST=127.0.0.1 instead.
VITE_API_PROTOCOL=http
VITE_API_HOST=10.0.2.2
VITE_API_PORT=4000
VITE_API_PATH=/api

# Advanced full override. If set, this wins over the split variables above.
# VITE_API_URL=http://10.0.2.2:4000/api
