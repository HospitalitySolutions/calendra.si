# Copy to .env.staging or export these before running:
# scripts/docker-compose-with-aws-secrets.sh staging up -d --build

# Prefer storing APP_JWT_SECRET in the same AWS Secrets Manager JSON as the datasource values.
# Keep it here only if you intentionally want this env file to override Secrets Manager.
# APP_JWT_SECRET=replace-with-at-least-32-characters-random-string

POSTGRES_DB=calendra_staging
POSTGRES_USER=calendra
# POSTGRES_PASSWORD is intentionally not stored here.
# Store POSTGRES_PASSWORD in AWS Secrets Manager (or use SPRING_DATASOURCE_PASSWORD as the same value)
# and start staging with: scripts/docker-compose-with-aws-secrets.sh staging up -d --build

STAGING_HTTP_PORT=8080
STAGING_HTTPS_PORT=8443

APP_PUBLIC_BASE_URL=http://localhost:3000
# Optional legacy override if auth/WebAuthn must use a different public frontend URL.
# APP_AUTH_FRONTEND_URL=http://localhost:3000

# Keep these relaxed while testing. Turn them on before public staging demos.
APP_RATE_LIMIT_BACKEND=auto
APP_WIDGET_RATE_LIMIT_BACKEND=auto
APP_WIDGET_REQUIRE_ALLOWED_ORIGIN=false
APP_WIDGET_TURNSTILE_REQUIRED_FOR_PUBLIC_ACTIONS=false

# Optional Redis/Sentry/OpenTelemetry/Turnstile settings
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
MANAGEMENT_OTLP_TRACING_ENDPOINT=
APP_WIDGET_TURNSTILE_SITE_KEY=
APP_WIDGET_TURNSTILE_SECRET_KEY=

AWS_REGION=eu-central-1
AWS_STAGING_SECRET_ID=calendra-staging
# Bunny video/audio storage (do not commit real credentials)
APP_BUNNY_ENABLED=true
BUNNY_API_KEY=
BUNNY_STREAM_BASE_URL=https://video.bunnycdn.com
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_REGION_HOST=https://storage.bunnycdn.com
BUNNY_AUDIO_CDN_HOST=

