# Copy to .env.staging or export these before running:
# docker compose --env-file .env.staging -f docker-compose.staging.yml up -d --build

APP_JWT_SECRET=replace-with-at-least-32-characters-random-string

POSTGRES_DB=calendra_staging
POSTGRES_USER=calendra
POSTGRES_PASSWORD=replace-with-random-staging-db-password

STAGING_HTTP_PORT=8080
STAGING_HTTPS_PORT=8443

APP_AUTH_FRONTEND_URL=http://localhost:3000

# Keep these relaxed while testing. Turn them on before public staging demos.
APP_RATE_LIMIT_BACKEND=auto
APP_WIDGET_RATE_LIMIT_BACKEND=auto
APP_WIDGET_REQUIRE_ALLOWED_ORIGIN=false
APP_WIDGET_TURNSTILE_REQUIRED_FOR_PUBLIC_ACTIONS=false

# Optional Redis/Sentry/OpenTelemetry/Turnstile settings
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
MANAGEMENT_OTLP_TRACING_ENDPOINT=
APP_WIDGET_TURNSTILE_SITE_KEY=
APP_WIDGET_TURNSTILE_SECRET_KEY=

AWS_REGION=eu-central-1
AWS_STAGING_SECRET_ID=calendra-staging
