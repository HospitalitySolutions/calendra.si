# Copy to .env.local next to this file (backend/.env.local) or repo root .env.local.
# Same variable names work in AWS Secrets Manager JSON for staging/production.
#
# Required for a running API (local):
SPRING_DATASOURCE_USERNAME=calendra
SPRING_DATASOURCE_PASSWORD=calendra
APP_JWT_SECRET=replace-with-at-least-32-characters-random-string
#
# Database URL (optional; default targets localhost:5432/calendradb)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/calendradb
#
# Mail (optional; leave SMTP user/pass empty to skip authenticated sending)
# SPRING_MAIL_HOST=email-smtp.eu-north-1.amazonaws.com
# SPRING_MAIL_PORT=465
# SPRING_MAIL_USERNAME=
# SPRING_MAIL_PASSWORD=
# APP_MAIL_FROM=noreply@yourdomain.com
#
# Google login (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://staging.calendra.si/login/oauth2/code/google
#
# Zoom / Infobip / OpenAI / Google Meet (optional)
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# INFOBIP_API_KEY=
# INFOBIP_SENDER=
# OPENAI_API_KEY=
# GOOGLE_MEET_CLIENT_ID=
# GOOGLE_MEET_CLIENT_SECRET=
#
# Bankart PSD2 (optional; required only for BANK tab integration)
# BANKART_API_KEY=
# BANKART_API_SECRET=
# BANKART_BASE_URL=https://api.bankart.si/psd2/otp/sandbox/v1
# BANKART_CALLBACK_URL=http://localhost:4000/api/bankart/callback
# BANKART_FRONTEND_URL=http://localhost:3000/configuration?tab=billing
#
# Frontend URL for password-reset links and OAuth errors
# APP_AUTH_FRONTEND_URL=http://localhost:3000
#
# Stripe Checkout (one-time card payment)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_BASE_URL=https://api.stripe.com
# STRIPE_CURRENCY=eur
# STRIPE_SUCCESS_URL=http://localhost:3000/billing/payment/success
# STRIPE_CANCEL_URL=http://localhost:3000/billing/payment/cancel
# STRIPE_WEBHOOK_URL=http://localhost:4000/api/stripe/webhook
# STRIPE_EU_BANK_TRANSFER_COUNTRY=NL
#
# Invoice PDF storage in S3 (optional; default off for local). When enabled, PDFs are written after
# successful fiscalization (and for paid card flows if fiscalization did not archive yet).
# Staging/production: set APP_INVOICE_S3_ENABLED=true, APP_INVOICE_S3_BUCKET, and optional APP_INVOICE_S3_PREFIX
# in the same Secrets Manager JSON as other keys. Grant the task/instance role s3:PutObject and s3:GetObject
# on the bucket (and kms:GenerateDataKey if using SSE-KMS).
# APP_INVOICE_S3_ENABLED=false
# APP_INVOICE_S3_BUCKET=
# APP_INVOICE_S3_PREFIX=invoices
#
# AWS credentials for Secrets Manager + S3 (staging/production JSON secret — same three names).
# Also used by spring.cloud.aws.credentials in application-staging.yml / application-production.yml.
# Lightsail: set these in the secret for app/runtime; on the server, still provide the same keys (systemd/cron/Docker
# env) for the *first* GetSecretValue call, or use a dedicated bootstrap user with only secretsmanager:GetSecretValue.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-central-1

# Local quality-of-life overrides
# APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
# APP_SERVER_INCLUDE_MESSAGE=always
# APP_SEED_ENABLED=true
# APP_SEED_DEMO_TENANTS_ENABLED=true
# APP_SEED_SUPER_ADMIN_ENABLED=true
