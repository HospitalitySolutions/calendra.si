<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="calendra-backend"/>
    <springProperty scope="context" name="env" source="spring.profiles.active" defaultValue="local"/>

    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${appName}","environment":"${env}"}</customFields>
            <includeMdc>true</includeMdc>
        </encoder>
    </appender>

    <root level="${LOG_LEVEL_ROOT:-INFO}">
        <appender-ref ref="JSON_CONSOLE"/>
    </root>

    <logger name="com.example.app" level="${LOG_LEVEL_APP:-INFO}"/>
</configuration>
