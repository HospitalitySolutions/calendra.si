diff -ruN '--exclude=node_modules' '--exclude=dist' '--exclude=target' '--exclude=.gradle' '--exclude=build' a/docs/operations/PRODUCTION_1000_TENANTS.md b/docs/operations/PRODUCTION_1000_TENANTS.md
