+}
+/* Guest app nested tabs */
+.guest-app-settings-card {
+    max-width: 880px;
+}
+
+.guest-app-settings-intro {
+    margin-bottom: 28px;
+}
+
+.guest-app-tabs {
+    display: flex;
+    align-items: center;
+    gap: 28px;
+    border-bottom: 1px solid var(--border);
+    margin-bottom: 28px;
+    overflow-x: auto;
+}
+
+.guest-app-tab {
+    position: relative;
+    appearance: none;
+    border: 0;
+    border-radius: 0;
+    background: transparent;
+    color: var(--color-text-muted);
+    box-shadow: none;
+    padding: 0 0 14px;
+    min-height: 34px;
+    font: inherit;
+    font-weight: 600;
+    white-space: nowrap;
+    cursor: pointer;
+    transition: color 0.15s ease;
+}
+
+.guest-app-tab::after {
+    content: '';
+    position: absolute;
+    left: 0;
+    right: 0;
+    bottom: -1px;
+    height: 2px;
+    border-radius: 999px 999px 0 0;
+    background: transparent;
+}
+
+.guest-app-tab:hover,
+.guest-app-tab.is-active {
+    color: var(--color-primary);
+    box-shadow: none;
+    transform: none;
+}
+
+.guest-app-tab.is-active::after {
+    background: var(--color-primary);
+}
+
+.guest-app-tab-panel {
+    min-height: 160px;
+}
+
+.guest-app-qr-panel {
+    padding-top: 14px;
+}
+
+.guest-app-qr-layout {
+    display: grid;
+    grid-template-columns: minmax(0, 1fr) auto 150px;
+    align-items: center;
+    gap: 32px;
+}
+
+.guest-app-qr-copy {
+    display: grid;
+    gap: 14px;
+    max-width: 360px;
+}
+
+.guest-app-qr-copy .section-title-row {
+    margin-bottom: 0;
+}
+
+.guest-app-tenant-code-row {
+    display: inline-flex;
+    align-items: center;
+    gap: 10px;
+    color: var(--color-text);
+    font-weight: 600;
+}
+
+.guest-app-tenant-code-pill {
+    display: inline-flex;
+    align-items: center;
+    padding: 5px 11px;
+    border-radius: 999px;
+    background: var(--color-primary-soft);
+    color: var(--color-primary);
+    font-size: 0.86rem;
+    font-weight: 700;
+    letter-spacing: 0.01em;
+}
+
+.guest-app-qr-note {
+    display: flex;
+    align-items: flex-start;
+    gap: 12px;
+    border-top: 1px solid var(--border);
+    margin-top: 6px;
+    padding-top: 16px;
+    color: var(--color-text-muted);
+    line-height: 1.5;
+}
+
+.guest-app-qr-note-icon {
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    width: 26px;
+    height: 26px;
+    flex: 0 0 26px;
+    border-radius: 50%;
+    background: var(--color-primary-soft);
+    color: var(--color-primary);
+    font-weight: 800;
+    font-size: 0.86rem;
+}
+
+.guest-app-qr-preview {
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    width: 192px;
+    height: 192px;
+    border: 1px solid var(--border);
+    border-radius: 16px;
+    background: #ffffff;
+    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.08);
+    padding: 14px;
+}
+
+.guest-app-qr-preview img,
+.guest-app-qr-preview svg {
+    width: 100%;
+    height: 100%;
+    display: block;
+}
+
+.guest-app-qr-placeholder {
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    width: 100%;
+    height: 100%;
+    border-radius: 12px;
+    background: #f8fafc;
+    color: var(--color-text-muted);
+    font-size: 0.88rem;
+    text-align: center;
+    padding: 12px;
+}
+
+.guest-app-qr-actions {
+    display: grid;
+    gap: 12px;
+}
+
+.guest-app-action-button {
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    gap: 10px;
+    min-width: 132px;
+    min-height: 48px;
+}
+
+.guest-app-action-button--outline {
+    background: #ffffff;
+    color: var(--color-primary);
+    border: 1px solid var(--color-primary);
+    box-shadow: none;
+}
+
+.guest-app-action-button--outline:hover {
+    background: var(--color-primary-soft);
+    box-shadow: none;
+}
+
+.guest-app-action-button--primary {
+    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 100%);
+    color: #ffffff;
+}
+
+[data-theme="dark"] .guest-app-tab {
+    color: var(--color-text-muted);
+}
+
+[data-theme="dark"] .guest-app-tab:hover,
+[data-theme="dark"] .guest-app-tab.is-active {
+    color: var(--color-primary);
+}
+
+[data-theme="dark"] .guest-app-action-button--outline {
+    background: rgba(255, 255, 255, 0.04);
+    color: var(--color-primary);
+    border-color: var(--color-primary);
+}
+
+[data-theme="dark"] .guest-app-qr-preview {
+    border-color: rgba(255, 255, 255, 0.14);
+}
+
+@media (max-width: 980px) {
+    .guest-app-qr-layout {
+        grid-template-columns: 1fr;
+        justify-items: start;
+    }
+
+    .guest-app-qr-actions {
+        display: flex;
+        flex-wrap: wrap;
+    }
+}
+
+@media (max-width: 640px) {
+    .guest-app-tabs {
+        gap: 20px;
+    }
+
+    .guest-app-qr-preview {
+        width: 168px;
+        height: 168px;
+    }
+}