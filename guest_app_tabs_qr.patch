@@ -0,0 +1,291 @@
+const QR_ALPHANUMERIC_CHARSET = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ $%*+-./:'
+const QR_VERSION = 4
+const QR_SIZE = 17 + QR_VERSION * 4
+const QR_DATA_CODEWORDS = 80
+const QR_ECC_CODEWORDS = 20
+const QR_ECL_FORMAT_BITS_L = 0b01
+const QR_MASK_PATTERN = 0
+
+type QrEncodingMode = 'alphanumeric' | 'byte'
+
+type QrPayload = {
+  mode: QrEncodingMode
+  bits: number[]
+}
+
+const appendBits = (target: number[], value: number, length: number) => {
+  if (length < 0 || length > 31 || value >>> length !== 0) {
+    throw new Error('Invalid QR bit segment.')
+  }
+  for (let i = length - 1; i >= 0; i -= 1) {
+    target.push((value >>> i) & 1)
+  }
+}
+
+const encodeQrPayload = (content: string): QrPayload => {
+  const normalized = content.trim()
+  if (!normalized) throw new Error('QR content is empty.')
+
+  const canUseAlphanumeric = [...normalized].every((char) => QR_ALPHANUMERIC_CHARSET.includes(char))
+  if (canUseAlphanumeric) {
+    const bits: number[] = []
+    for (let i = 0; i < normalized.length; i += 2) {
+      if (i + 1 < normalized.length) {
+        const value = QR_ALPHANUMERIC_CHARSET.indexOf(normalized[i]) * 45 + QR_ALPHANUMERIC_CHARSET.indexOf(normalized[i + 1])
+        appendBits(bits, value, 11)
+      } else {
+        appendBits(bits, QR_ALPHANUMERIC_CHARSET.indexOf(normalized[i]), 6)
+      }
+    }
+    return { mode: 'alphanumeric', bits }
+  }
+
+  const bytes = new TextEncoder().encode(normalized)
+  const bits: number[] = []
+  for (const byte of bytes) appendBits(bits, byte, 8)
+  return { mode: 'byte', bits }
+}
+
+const buildDataCodewords = (content: string): number[] => {
+  const payload = encodeQrPayload(content)
+  const normalized = content.trim()
+  const bits: number[] = []
+  const contentLength = payload.mode === 'byte' ? new TextEncoder().encode(normalized).length : normalized.length
+
+  if (payload.mode === 'alphanumeric') {
+    appendBits(bits, 0b0010, 4)
+    appendBits(bits, contentLength, 9)
+  } else {
+    appendBits(bits, 0b0100, 4)
+    appendBits(bits, contentLength, 8)
+  }
+  bits.push(...payload.bits)
+
+  const capacityBits = QR_DATA_CODEWORDS * 8
+  if (bits.length > capacityBits) {
+    throw new Error('QR content is too long for the selected QR version.')
+  }
+
+  appendBits(bits, 0, Math.min(4, capacityBits - bits.length))
+  while (bits.length % 8 !== 0) bits.push(0)
+
+  const dataCodewords: number[] = []
+  for (let i = 0; i < bits.length; i += 8) {
+    let byte = 0
+    for (let j = 0; j < 8; j += 1) byte = (byte << 1) | bits[i + j]
+    dataCodewords.push(byte)
+  }
+
+  for (let pad = 0; dataCodewords.length < QR_DATA_CODEWORDS; pad += 1) {
+    dataCodewords.push(pad % 2 === 0 ? 0xec : 0x11)
+  }
+  return dataCodewords
+}
+
+const createGaloisTables = () => {
+  const exp = new Array<number>(512).fill(0)
+  const log = new Array<number>(256).fill(0)
+  let value = 1
+  for (let i = 0; i < 255; i += 1) {
+    exp[i] = value
+    log[value] = i
+    value <<= 1
+    if (value & 0x100) value ^= 0x11d
+  }
+  for (let i = 255; i < 512; i += 1) exp[i] = exp[i - 255]
+  return { exp, log }
+}
+
+const QR_GF = createGaloisTables()
+
+const gfMultiply = (left: number, right: number) => {
+  if (left === 0 || right === 0) return 0
+  return QR_GF.exp[QR_GF.log[left] + QR_GF.log[right]]
+}
+
+const reedSolomonGenerator = (degree: number): number[] => {
+  let poly = [1]
+  for (let i = 0; i < degree; i += 1) {
+    const next = new Array<number>(poly.length + 1).fill(0)
+    for (let j = 0; j < poly.length; j += 1) {
+      next[j] ^= poly[j]
+      next[j + 1] ^= gfMultiply(poly[j], QR_GF.exp[i])
+    }
+    poly = next
+  }
+  return poly
+}
+
+const reedSolomonRemainder = (data: number[], degree: number): number[] => {
+  const generator = reedSolomonGenerator(degree)
+  const result = data.concat(new Array<number>(degree).fill(0))
+  for (let i = 0; i < data.length; i += 1) {
+    const coefficient = result[i]
+    if (coefficient === 0) continue
+    for (let j = 0; j < generator.length; j += 1) {
+      result[i + j] ^= gfMultiply(generator[j], coefficient)
+    }
+  }
+  return result.slice(data.length)
+}
+
+const buildMessageCodewords = (content: string): number[] => {
+  const data = buildDataCodewords(content)
+  return data.concat(reedSolomonRemainder(data, QR_ECC_CODEWORDS))
+}
+
+const maskBit = (x: number, y: number) => (x + y) % 2 === 0
+
+const formatBits = (errorCorrectionLevelBits: number, maskPattern: number): number => {
+  const data = (errorCorrectionLevelBits << 3) | maskPattern
+  let remainder = data
+  for (let i = 0; i < 10; i += 1) {
+    remainder = (remainder << 1) ^ (((remainder >>> 9) & 1) ? 0x537 : 0)
+  }
+  return ((data << 10) | remainder) ^ 0x5412
+}
+
+const bitAt = (value: number, index: number) => ((value >>> index) & 1) === 1
+
+const createEmptyMatrix = () => ({
+  modules: Array.from({ length: QR_SIZE }, () => new Array<boolean>(QR_SIZE).fill(false)),
+  reserved: Array.from({ length: QR_SIZE }, () => new Array<boolean>(QR_SIZE).fill(false)),
+})
+
+const inBounds = (x: number, y: number) => x >= 0 && y >= 0 && x < QR_SIZE && y < QR_SIZE
+
+const drawFunctionModule = (
+  modules: boolean[][],
+  reserved: boolean[][],
+  x: number,
+  y: number,
+  dark: boolean,
+) => {
+  if (!inBounds(x, y)) return
+  modules[y][x] = dark
+  reserved[y][x] = true
+}
+
+const drawFinder = (modules: boolean[][], reserved: boolean[][], left: number, top: number) => {
+  for (let dy = -1; dy <= 7; dy += 1) {
+    for (let dx = -1; dx <= 7; dx += 1) {
+      const x = left + dx
+      const y = top + dy
+      if (!inBounds(x, y)) continue
+      const isFinder = dx >= 0 && dx <= 6 && dy >= 0 && dy <= 6 && (
+        dx === 0 || dx === 6 || dy === 0 || dy === 6 || (dx >= 2 && dx <= 4 && dy >= 2 && dy <= 4)
+      )
+      drawFunctionModule(modules, reserved, x, y, isFinder)
+    }
+  }
+}
+
+const drawAlignment = (modules: boolean[][], reserved: boolean[][], centerX: number, centerY: number) => {
+  for (let dy = -2; dy <= 2; dy += 1) {
+    for (let dx = -2; dx <= 2; dx += 1) {
+      const x = centerX + dx
+      const y = centerY + dy
+      if (!inBounds(x, y) || reserved[y][x]) continue
+      const distance = Math.max(Math.abs(dx), Math.abs(dy))
+      drawFunctionModule(modules, reserved, x, y, distance !== 1)
+    }
+  }
+}
+
+const drawTimingPatterns = (modules: boolean[][], reserved: boolean[][]) => {
+  for (let i = 8; i < QR_SIZE - 8; i += 1) {
+    const dark = i % 2 === 0
+    if (!reserved[6][i]) drawFunctionModule(modules, reserved, i, 6, dark)
+    if (!reserved[i][6]) drawFunctionModule(modules, reserved, 6, i, dark)
+  }
+}
+
+const reserveFormatAreas = (modules: boolean[][], reserved: boolean[][]) => {
+  for (let i = 0; i <= 8; i += 1) {
+    if (i !== 6) {
+      drawFunctionModule(modules, reserved, 8, i, false)
+      drawFunctionModule(modules, reserved, i, 8, false)
+    }
+  }
+  for (let i = 0; i < 8; i += 1) drawFunctionModule(modules, reserved, QR_SIZE - 1 - i, 8, false)
+  for (let i = 0; i < 7; i += 1) drawFunctionModule(modules, reserved, 8, QR_SIZE - 1 - i, false)
+  drawFunctionModule(modules, reserved, 8, 4 * QR_VERSION + 9, true)
+}
+
+const drawFormatBits = (modules: boolean[][], reserved: boolean[][]) => {
+  const bits = formatBits(QR_ECL_FORMAT_BITS_L, QR_MASK_PATTERN)
+  for (let i = 0; i <= 5; i += 1) drawFunctionModule(modules, reserved, 8, i, bitAt(bits, i))
+  drawFunctionModule(modules, reserved, 8, 7, bitAt(bits, 6))
+  drawFunctionModule(modules, reserved, 8, 8, bitAt(bits, 7))
+  drawFunctionModule(modules, reserved, 7, 8, bitAt(bits, 8))
+  for (let i = 9; i < 15; i += 1) drawFunctionModule(modules, reserved, 14 - i, 8, bitAt(bits, i))
+
+  for (let i = 0; i < 8; i += 1) drawFunctionModule(modules, reserved, QR_SIZE - 1 - i, 8, bitAt(bits, i))
+  for (let i = 8; i < 15; i += 1) drawFunctionModule(modules, reserved, 8, QR_SIZE - 15 + i, bitAt(bits, i))
+  drawFunctionModule(modules, reserved, 8, 4 * QR_VERSION + 9, true)
+}
+
+const drawCodewords = (modules: boolean[][], reserved: boolean[][], codewords: number[]) => {
+  const bits: number[] = []
+  for (const codeword of codewords) appendBits(bits, codeword, 8)
+
+  let bitIndex = 0
+  let upward = true
+  for (let right = QR_SIZE - 1; right >= 1; right -= 2) {
+    if (right === 6) right -= 1
+    for (let vertical = 0; vertical < QR_SIZE; vertical += 1) {
+      const y = upward ? QR_SIZE - 1 - vertical : vertical
+      for (let dx = 0; dx < 2; dx += 1) {
+        const x = right - dx
+        if (reserved[y][x]) continue
+        const dark = bitIndex < bits.length ? bits[bitIndex] === 1 : false
+        modules[y][x] = dark !== maskBit(x, y)
+        bitIndex += 1
+      }
+    }
+    upward = !upward
+  }
+}
+
+const escapeXml = (value: string) => value.replace(/[&<>'"]/g, (char) => {
+  const entities: Record<string, string> = {
+    '&': '&amp;',
+    '<': '&lt;',
+    '>': '&gt;',
+    "'": '&apos;',
+    '"': '&quot;',
+  }
+  return entities[char] || char
+})
+
+const createQrMatrix = (content: string): boolean[][] => {
+  const { modules, reserved } = createEmptyMatrix()
+  drawFinder(modules, reserved, 0, 0)
+  drawFinder(modules, reserved, QR_SIZE - 7, 0)
+  drawFinder(modules, reserved, 0, QR_SIZE - 7)
+  drawTimingPatterns(modules, reserved)
+  drawAlignment(modules, reserved, QR_SIZE - 7, QR_SIZE - 7)
+  reserveFormatAreas(modules, reserved)
+  drawCodewords(modules, reserved, buildMessageCodewords(content))
+  drawFormatBits(modules, reserved)
+  return modules
+}
+
+export const createQrSvg = (content: string, scale = 8) => {
+  const normalized = content.trim()
+  if (!normalized) throw new Error('QR content is empty.')
+  const quietZone = 4
+  const matrix = createQrMatrix(normalized)
+  const viewBoxSize = QR_SIZE + quietZone * 2
+  const moduleSize = Math.max(1, scale)
+  const renderedSize = viewBoxSize * moduleSize
+  const paths: string[] = []
+
+  for (let y = 0; y < QR_SIZE; y += 1) {
+    for (let x = 0; x < QR_SIZE; x += 1) {
+      if (matrix[y][x]) paths.push(`M${x + quietZone} ${y + quietZone}h1v1h-1z`)
+    }
+  }
+
+  return `<svg xmlns="http://www.w3.org/2000/svg" width="${renderedSize}" height="${renderedSize}" viewBox="0 0 ${viewBoxSize} ${viewBoxSize}" role="img" aria-label="QR code for ${escapeXml(normalized)}" shape-rendering="crispEdges"><rect width="100%" height="100%" fill="#fff"/><path d="${paths.join(' ')}" fill="#000"/></svg>`
+}
